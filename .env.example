# ── Furix Gemma MVP — configuration (copy to .env) ───────────────────────────

# In-house Gemma inference endpoint (OpenAI-compatible /v1; Ollama or vLLM)
GEMMA_BASE_URL=http://YOUR_GEMMA_HOST:11434/v1
GEMMA_MODEL=gemma4:e4b
GEMMA_API_KEY=ollama
GEMMA_TIMEOUT=120
GEMMA_MAX_TOKENS=1600
GEMMA_TEMPERATURE=0.1

# Set MOCK_LLM=1 to run the full pipeline without a reachable Gemma
# (deterministic stub responses — for local/offline verification).
MOCK_LLM=0

# DAL HIPAA Safe Harbor redaction (SSN/phone/date/VIN/URL). OFF for SIEM logs
# (those patterns over-redact); ON only when analyzing healthcare/PHI data.
DAL_HIPAA_MODE=0

# ── Full RAG grounding (PostgreSQL 16 + pgvector + Apache AGE) ────────────────
# Leave RAG_ENABLED=0 to run agents on static-map grounding only (no DB needed).
RAG_ENABLED=0
PG_HOST=localhost
PG_PORT=5433
PG_DBNAME=cis_rag
PG_USER=colab_user
PG_PASSWORD=colab_pass
PG_TABLE=compliance_chunks
AGE_GRAPH_NAME=compliance_graph
EMBED_MODEL=cisco-ai/SecureBERT2.0-biencoder
RERANK_MODEL=cisco-ai/SecureBERT2.0-cross_encoder
EMBED_DIM=768

# Run a subset of agents (comma-separated) or "all"
ENABLED_AGENTS=all

# Run the 5 agents concurrently (1) or sequentially (0)
PARALLEL_AGENTS=1

# ── Cloud ↔ Appliance bridge (see docs/BUNDLE-CONTRACT.md) ────────────────────
# Furix Cloud endpoint the appliance pulls the signed baseline bundle from.
# Leave blank to demo the appliance side with the bundled sample
# (Baseline tab → "Load sample bundle"). When the Cloud is live, set e.g.
# CLOUD_BUNDLE_URL=http://furix-cloud:9000  (appliance GETs {URL}/bundle/latest)
CLOUD_BUNDLE_URL=
